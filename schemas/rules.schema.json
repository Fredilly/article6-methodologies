{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R-\\d+(?:-\\d+)*-\\d{4}$"
          },
          "stable_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "logic": {
            "type": "string",
            "minLength": 1
          },
          "section_anchor": {
            "type": "string",
            "minLength": 1
          },
          "section_id": {
            "type": "string",
            "pattern": "^S-\\d+(?:-\\d+)*$"
          },
          "section_number": {
            "type": "string",
            "minLength": 1
          },
          "section_stable_id": {
            "type": "string",
            "minLength": 1
          },
          "tools": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "id",
          "stable_id",
          "title",
          "logic",
          "section_anchor",
          "section_id",
          "section_number",
          "section_stable_id",
          "tools"
        ]
      }
    }
  },
  "required": [
    "rules"
  ]
}
