{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "rules": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "expectedEvidence": {
            "description": "Evidence types a reviewer should look for to verify this rule",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "id": {
            "pattern": "^R-\\d+(?:-\\d+)*-\\d{4}$",
            "type": "string"
          },
          "logic": {
            "minLength": 1,
            "type": "string"
          },
          "section_anchor": {
            "minLength": 1,
            "type": "string"
          },
          "section_id": {
            "pattern": "^S-\\d+(?:-\\d+)*$",
            "type": "string"
          },
          "section_number": {
            "minLength": 1,
            "type": "string"
          },
          "section_stable_id": {
            "minLength": 1,
            "type": "string"
          },
          "stable_id": {
            "minLength": 1,
            "type": "string"
          },
          "tags": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "tools": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "when": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "id",
          "stable_id",
          "title",
          "logic",
          "section_anchor",
          "section_id",
          "section_number",
          "section_stable_id",
          "tools"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "rules"
  ],
  "type": "object"
}
