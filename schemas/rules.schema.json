{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "stable_id": { "type": "string" },
          "title": { "type": "string" },
          "logic": { "type": "string" },
          "type": { "type": "string" },
          "text": { "type": "string" },
          "refs": { "type": "object" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
