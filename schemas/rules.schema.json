{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "rules": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "logic": {
            "type": "string"
          },
          "section_anchor": {
            "type": "string"
          },
          "section_id": {
            "type": "string"
          },
          "section_number": {
            "type": "string"
          },
          "section_stable_id": {
            "type": "string"
          },
          "stable_id": {
            "type": "string"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "text": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "tools": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "when": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "id"
        ],
        "anyOf": [
          {
            "required": [
              "title"
            ]
          },
          {
            "required": [
              "text"
            ]
          }
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "rules"
  ],
  "type": "object"
}
