{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "sections": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "anchor": {
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "pattern": "^S-\\d+(?:-\\d+)*$",
            "type": "string"
          },
          "pages": {
            "items": {
              "minimum": 1,
              "type": "integer"
            },
            "minItems": 1,
            "type": "array"
          },
          "section_number": {
            "minLength": 1,
            "type": "string"
          },
          "stable_id": {
            "minLength": 1,
            "type": "string"
          },
          "title": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "anchor",
          "section_number",
          "stable_id"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "sections"
  ],
  "type": "object"
}
