{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S-\\d+(?:-\\d+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "anchor": {
            "type": "string",
            "minLength": 1
          },
          "section_number": {
            "type": "string",
            "minLength": 1
          },
          "stable_id": {
            "type": "string",
            "minLength": 1
          },
          "pages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "required": [
          "id",
          "title",
          "anchor",
          "section_number",
          "stable_id"
        ]
      }
    }
  },
  "required": [
    "sections"
  ]
}
