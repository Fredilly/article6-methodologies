{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "items": {
    "additionalProperties": false,
    "properties": {
      "display": {
        "additionalProperties": false,
        "properties": {
          "logic": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "when": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "id": {
        "pattern": "^[A-Za-z0-9]+\\.[A-Za-z0-9]+\\.[A-Za-z0-9-]+\\.[vV][0-9][A-Za-z0-9\\.-]*\\.R-\\d+(?:-\\d+)*-\\d{4}$",
        "type": "string"
      },
      "inputs": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "choices": {
              "items": {},
              "type": "array"
            },
            "default": {},
            "name": {
              "minLength": 1,
              "type": "string"
            },
            "nullable": {
              "type": "boolean"
            },
            "source": {
              "type": "string"
            },
            "unit": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "type": "object"
        },
        "type": "array"
      },
      "logic": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "notes": {
        "type": "string"
      },
      "provenance": {
        "additionalProperties": false,
        "properties": {
          "source_hash": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "source_ref": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "refs": {
        "additionalProperties": false,
        "properties": {
          "lines": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "locators": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "hint": {
                  "type": "string"
                },
                "pages": {
                  "items": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "type": "array"
                },
                "quote": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "quote"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "methodology": {
            "type": "string"
          },
          "pages": {
            "items": {
              "minimum": 1,
              "type": "integer"
            },
            "type": "array"
          },
          "primary_section": {
            "pattern": "^S-\\d+(?:-\\d+)*$",
            "type": "string"
          },
          "section_anchor": {
            "type": "string"
          },
          "section_number": {
            "type": "string"
          },
          "section_stable_id": {
            "type": "string"
          },
          "sections": {
            "items": {
              "pattern": "^S-\\d+(?:-\\d+)*$",
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "tools": {
            "items": {
              "pattern": "^[A-Za-z0-9\\-/.]+@v[0-9][A-Za-z0-9\\.-]*$",
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "sections"
        ],
        "type": "object"
      },
      "requirement_coverage": {
        "additionalProperties": false,
        "properties": {
          "coverage_key": {
            "type": "string"
          },
          "coverage_scope": {
            "enum": [
              "rule"
            ],
            "type": "string"
          },
          "expected_evidence": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "description": {
                  "minLength": 1,
                  "type": "string"
                },
                "id": {
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                  "type": "string"
                },
                "label": {
                  "minLength": 1,
                  "type": "string"
                },
                "required": {
                  "type": "boolean"
                }
              },
              "required": [
                "id",
                "label",
                "description",
                "required"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "section_refs": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "relationship": {
                  "enum": [
                    "source_section"
                  ],
                  "type": "string"
                },
                "section_id": {
                  "pattern": "^S-\\d+(?:-\\d+)*$",
                  "type": "string"
                }
              },
              "required": [
                "section_id",
                "relationship"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "coverage_key",
          "coverage_scope"
        ],
        "type": "object"
      },
      "requirement_kind": {
        "type": "string"
      },
      "requirement_text": {
        "minLength": 1,
        "type": "string"
      },
      "rule_detail": {
        "additionalProperties": false,
        "properties": {
          "conditions": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "exceptions": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "outputs": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "type": "object"
      },
      "section_context": {
        "additionalProperties": false,
        "properties": {
          "anchor": {
            "minLength": 1,
            "type": "string"
          },
          "lineage": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "page_end": {
            "minimum": 1,
            "type": "integer"
          },
          "page_start": {
            "minimum": 1,
            "type": "integer"
          },
          "section_id": {
            "pattern": "^S-\\d+(?:-\\d+)*$",
            "type": "string"
          },
          "section_ref": {
            "minLength": 1,
            "type": "string"
          },
          "section_title": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "section_id",
          "section_title",
          "section_ref"
        ],
        "type": "object"
      },
      "source_span_text": {
        "minLength": 1,
        "type": "string"
      },
      "stable_id": {
        "type": "string"
      },
      "summary": {
        "minLength": 1,
        "type": "string"
      },
      "tags": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "type": {
        "enum": [
          "eligibility",
          "parameter",
          "equation",
          "calc",
          "monitoring",
          "leakage",
          "uncertainty",
          "reporting"
        ],
        "type": "string"
      },
      "when": {
        "items": {
          "minLength": 1,
          "type": "string"
        },
        "type": "array"
      }
    },
    "required": [
      "id",
      "type",
      "refs",
      "summary"
    ],
    "type": "object"
  },
  "title": "Rules (Rich) v1",
  "type": "array"
}
