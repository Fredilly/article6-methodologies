{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "items": {
    "additionalProperties": false,
    "properties": {
      "anchor": {
        "type": "string"
      },
      "id": {
        "pattern": "^S-\\d+(?:-\\d+)*$",
        "type": "string"
      },
      "level": {
        "minimum": 1,
        "type": "integer"
      },
      "locators": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "hint": {
              "type": "string"
            },
            "pages": {
              "items": {
                "minimum": 1,
                "type": "integer"
              },
              "type": "array"
            },
            "quote": {
              "type": "string"
            },
            "type": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "quote"
          ],
          "type": "object"
        },
        "type": "array"
      },
      "notes": {
        "type": "string"
      },
      "pages": {
        "items": {
          "minimum": 1,
          "type": "integer"
        },
        "type": "array"
      },
      "page_end": {
        "minimum": 1,
        "type": "integer"
      },
      "page_start": {
        "minimum": 1,
        "type": "integer"
      },
      "provenance": {
        "additionalProperties": false,
        "properties": {
          "lines": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "source_hash": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "source_ref": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "section_number": {
        "type": "string"
      },
      "summary": {
        "minLength": 1,
        "type": "string"
      },
      "lineage": {
        "items": {
          "minLength": 1,
          "type": "string"
        },
        "minItems": 1,
        "type": "array"
      },
      "stable_id": {
        "type": "string"
      },
      "title": {
        "minLength": 1,
        "type": "string"
      },
      "workflow_role": {
        "minLength": 1,
        "type": "string"
      }
    },
    "required": [
      "id",
      "title"
    ],
    "type": "object"
  },
  "title": "Sections (Rich) v1",
  "type": "array"
}
